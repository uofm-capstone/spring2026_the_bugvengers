<!-- app/views/pages/home.html.erb -->
<div class="container mt-4">
  <div class="row g-4">
    <div class="mb-4">
      <h1 class="fw-bold">Tool-Assisted Grading (TAG)</h1>
      <p class="text-muted">
        Welcome! 
        Automate, assist, and accelerate your grading process with intelligent feedback and streamlined evaluation tools.
      </p>
    </div>
    <div class="col-12 col-md-6">
      <div class="card h-100 shadow-sm p-3">
        <h4>📚 Semester Management</h4>
        <p>Select and manage different semesters.</p>
        <p>View semester details and timelines.</p>
        <%= link_to "Go to Semesters", semesters_path, class: "btn btn-primary mt-3" %>
      </div>
    </div>
    <div class="col-12 col-md-6">
      <div class="card h-100 shadow-sm p-3">
        <h4>👥 Students</h4>
        <p>View all students.</p>
        <p>View students status. </p>
        <%= link_to "View Students", students_path, class: "btn btn-primary mt-auto" %>
      </div>
    </div>
    <div class="col-12 col-md-6">
      <div class="card h-100 shadow-sm p-3">
        <h4>🧑‍🤝‍🧑 Teams</h4>
        <p></p>
        <p>Organize students into teams.</p>
        <p>Manage group assignments.</p>
        <p>View team details and members.</p>
        <%= link_to "Manage Teams", teams_path, class: "btn btn-primary mt-3" %>
      </div>
    </div>
    <div class="col-12 col-md-6">
      <div class="card h-100 shadow-sm p-3">
        <h4>💻 GitHub Activity</h4>
        <p>Track commits.</p>
        <p>Monitor student contributions.</p>
        <%= link_to "View GitHub Status", status_page_path, class: "btn btn-primary mt-auto" %>
      </div>
    </div>
  </div>
</div>