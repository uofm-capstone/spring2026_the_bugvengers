<!-- TABLE -->
<div class="table-responsive team-status-table-wrap">
  <table class="table table-bordered align-middle text-center team-status-table">
    <thead>
      <tr>
        <th class="sticky-col-1" rowspan="3">Team Name</th>
        <th class="sticky-col-2" rowspan="3">Member</th>
        <% sprint_list.each do |sprint| %>
          <th colspan="15" class="sprint-group <%= sprint.parameterize %>"><%= sprint %></th>
        <% end %>
      </tr>

      <tr>
        <% sprint_list.each do |sprint| %>
          <th colspan="4" class="sprint-group <%= sprint.parameterize %>">Planning</th>
          <th colspan="4" class="sprint-group <%= sprint.parameterize %>">PC</th>
          <th colspan="7" class="sprint-group <%= sprint.parameterize %>">Demo</th>
        <% end %>
      </tr>

      <tr>
        <% rubric_items = ["FS&D", "FA", "TE", "KU", "TS", "PP", "CC", "SR", "TSP", "PP", "PF", "CBP", "CC", "SR", "D"] %>
        <% sprint_list.each do |sprint| %>
          <% rubric_items.each do |item| %>
            <% tooltip = case item
              when "FS&D" then "<strong>Feature Selection and Decomposition</strong><br><b>Metric:</b> Number of cards per column."
              when "FA"   then "<strong>Feature Assignments</strong><br><b>Metric:</b> Number of cards assigned to each team member."
              when "TE"   then "<strong>Feature Time Estimates</strong><br><b>Metric:</b> Sum of estimated hours per team member."
              when "KU"   then "<strong>Kanban Updates</strong><br><b>Metric:</b> N/A."
              when "TS"   then "<strong>Time Spent</strong><br><b>Metric:</b> N/A."
              when "PP"   then "<strong>Product Progress</strong><br><b>Metric:</b> Distinguishes current board Done from Done in this sprint column."
              when "CC"   then "<strong>Client Communication</strong><br><b>Metric:</b> N/A."
              when "CBP"  then "<strong>Coding Best Practices</strong><br><b>Metric:</b> Count of commits and line changes."
              when "SR"   then "<strong>Status and Reflection</strong><br><b>Metric:</b> N/A."
              when "TSP"  then "<strong>Time Spent Since Progress Check</strong><br><b>Metric:</b> Work hours or updates since last check."
              when "PF"   then "<strong>Product Feedback</strong><br><b>Metric:</b> N/A."
              when "D"    then "<strong>Demo</strong><br><b>Metric:</b> N/A."
              else "<strong>Metric</strong><br><b>Metric:</b> Description unavailable."
            end %>

            <th
              class="sprint-group <%= sprint.parameterize %>"
              data-bs-toggle="tooltip"
              data-bs-html="true"
              data-bs-placement="top"
              title="<%= tooltip.html_safe %>"
              style="font-size: 0.75rem;">
              <%= item %>
            </th>
          <% end %>
        <% end %>
      </tr>
    </thead>

    <tbody>
      <% teams.each do |team| %>
        <% team_summary = team_overview_by_id[team.id] || {} %>
        <% team.students.each_with_index do |student, i| %>
          <tr
            data-team-filter="1"
            data-team-id="<%= team.id %>"
            data-at-risk="<%= team_summary[:any_at_risk] %>"
            data-missing-done="<%= team_summary[:any_missing_sprint_done] %>">
            <% if i == 0 %>
              <td class="sticky-col-1" rowspan="<%= team.students.size %>">
                <div class="sticky-cell">
                  <%= link_to team.name, teams_path(semester), class: "text-decoration-none fw-semibold" %>
                  <% if team_summary[:any_at_risk] %>
                    <span class="team-risk-badge">At Risk</span>
                  <% end %>
                </div>
              </td>
            <% end %>

            <td class="sticky-col-2">
              <div class="sticky-cell">
                <%= "#{student.name.split.first} #{student.name.split.last&.first}." %>
              </div>
            </td>

            <% sprint_list.each do |sprint| %>
              <% rubric_items.each do |item| %>
                <td class="text-center sprint-group <%= sprint.parameterize %>">
                  <% case item %>
                    <% when "FS&D" %>
                      <% if !team_project_data.nil? %>
                        <% column_count = service.get_card_count_per_column(team_project_data[team.id]) %>
                        <%= "#{column_count['Backlog']}, #{column_count['Todo']}, #{column_count['In Progress']}, #{column_count['Done']}" %>
                      <% end %>
                    <% when "FA" %>
                      <% if !team_project_data.nil? %>
                        <% assigned_count = service.get_card_count_per_assignee(team_project_data[team.id], student.github_username)[student.github_username] %>
                        <%= assigned_count %>
                      <% end %>
                    <% when "TE" %>
                      <% if !team_project_data.nil? %>
                        <% estimated_hours = service.get_total_hours_per_assignee(team_project_data[team.id], student.github_username)[student.github_username] %>
                        <%= estimated_hours %>
                      <% end %>
                    <% when "KU" %>
                      <% metric = team_sprint_metrics.dig(team.id, sprint) || {} %>
                      <div class="status-metric-stack">
                        <span><strong>Archived:</strong> <%= metric[:archived_column_exists] ? 'Yes' : 'No' %></span>
                        <span><strong>Active:</strong> <%= metric[:active_now_cards] || 0 %></span>
                      </div>
                    <% when "PP" %>
                      <% metric = team_sprint_metrics.dig(team.id, sprint) || {} %>
                      <div class="status-metric-stack">
                        <span><strong>Board Done:</strong> <%= metric[:current_board_done_cards] || 0 %></span>
                        <span><strong><%= sprint %>:</strong> <%= metric[:sprint_done_cards] || 0 %></span>
                        <span><strong>Total:</strong> <%= metric[:total_cards] || 0 %></span>
                      </div>

                    <% when "CBP" %>
                      <% metric = status_metrics.dig(team.id, student.id, sprint, :cbp) %>
                      <div class="status-metric-stack">
                        <span><strong>Commits:</strong> <%= metric&.commit_count || 0 %></span>
                        <span><strong>LOC:</strong> <%= metric&.lines_changed || 0 %></span>
                      </div>

                    <% when "TSP" %>
                      <% metric = status_metrics.dig(team.id, student.id, sprint, :tsp) || {} %>
                      <div class="status-metric-stack">
                        <span><strong>Commits:</strong> <%= metric[:commit_count_since_progress] || 0 %></span>
                        <span><strong>LOC:</strong> <%= metric[:lines_changed_since_progress] || 0 %></span>
                        <span><strong>Stale:</strong> <%= metric[:stale_assigned_tasks] || 0 %></span>
                      </div>

                    <% when "TS", "CC", "SR", "PF", "D" %>
                      <span class="ui-tooltip" tabindex="0" aria-label="No data / N/A" data-tooltip="No data / N/A">
                        <%= image_tag "question-circle-fill.svg", class: "team-status-icon", alt: "", aria: { hidden: true } %>
                      </span>

                    <% else %>
                      <span class="ui-tooltip" tabindex="0" aria-label="No data / N/A" data-tooltip="No data / N/A">
                        <%= image_tag "question-circle-fill.svg", class: "team-status-icon", alt: "", aria: { hidden: true } %>
                      </span>
                  <% end %>
                </td>
              <% end %>
            <% end %>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
