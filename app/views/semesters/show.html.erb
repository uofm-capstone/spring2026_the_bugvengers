<%= render "shared/page_header",
  title: "Semester Overview",
  subtitle: @semester.name_for_select %>

  <div class="container mt-3 semesters-show">
    <div class="d-flex">
      <div class="main-content">

        <!-- Warning for No Student CSV Uploaded -->
        <% unless @semester.student_csv.attached? %>
          <div class="d-flex justify-content-center mt-4 mb-4">
            <div class="card w-100 border-danger">
              <div class="card-body bg-danger text-white">
                <p class="card-text text-center">
                  <strong>Attention:</strong> No Student CSV has been uploaded for this semester. Please upload the student CSV to display the data.
                </p>
              </div>
            </div>
          </div>
        <% end %>

        <div class="row">
          <div class="mt-4 text-center">
            <h2>Team Status</h2>
            <div class="alert alert-info" role="status" id="status-load-panel">
              <div class="mb-2">Loading status metrics from GitHub. This page is ready while data loads.</div>
              <div class="progress" style="height: 0.9rem;">
                <div
                  id="status-load-bar"
                  class="progress-bar progress-bar-striped progress-bar-animated"
                  role="progressbar"
                  style="width: 8%;"
                  aria-valuemin="0"
                  aria-valuemax="100"
                  aria-valuenow="8">8%</div>
              </div>
              <small id="status-load-text" class="d-block mt-2 text-muted">Fetching Kanban + GitHub data...</small>
            </div>
          </div>
        </div>

        <%= turbo_frame_tag "semester-status-content",
          src: semester_status_content_path(@semester, debug: params[:debug]) do %>
          <div class="text-center text-muted py-3" id="status-frame-placeholder">
            Preparing status content...
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%= javascript_include_tag 'survey_page/survey_scroll_navigation' %>
  <%= javascript_include_tag 'survey_page/survey_page_expanding_cols' %>
  <%= javascript_include_tag 'octokit', type: "module" %>

  <script>
    // Initialise tooltips + sprint filter (for both normal and Turbo loads)
    function initTooltipsAndSprintFilter() {
      // Tooltips
      const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');
      tooltipTriggerList.forEach(el => new bootstrap.Tooltip(el));

      // Sprint filter
      const buttons = document.querySelectorAll(".sprint-toggle");
      const groups  = document.querySelectorAll(".sprint-group");

      if (!buttons.length || !groups.length) return;

      // Default: All visible
      groups.forEach(g => g.style.display = "");

      buttons.forEach(btn => {
        // avoid double-binding
        if (btn.dataset.sprintBound === "1") return;
        btn.dataset.sprintBound = "1";

        btn.addEventListener("click", () => {
          buttons.forEach(b => b.classList.remove("active"));
          btn.classList.add("active");

          const key = btn.dataset.sprint;  // "all" or e.g. "sprint-1"

          if (key === "all") {
            groups.forEach(g => g.style.display = "");
          } else {
            groups.forEach(g => {
              g.style.display = g.classList.contains(key) ? "" : "none";
            });
          }
        });
      });

      const teamFilterButtons = document.querySelectorAll('.team-filter');
      const teamRows = document.querySelectorAll('tr[data-team-filter="1"]');
      const teamCards = document.querySelectorAll('[data-team-card="1"]');

      function shouldShowForFilter(element, filter) {
        if (filter === 'all') return true;
        if (filter === 'at-risk') return element.dataset.atRisk === 'true';
        if (filter === 'missing-done') return element.dataset.missingDone === 'true';
        return true;
      }

      function applyTeamFilter(filter) {
        teamRows.forEach(row => {
          row.style.display = shouldShowForFilter(row, filter) ? '' : 'none';
        });

        teamCards.forEach(card => {
          card.style.display = shouldShowForFilter(card, filter) ? '' : 'none';
        });
      }

      teamFilterButtons.forEach(button => {
        if (button.dataset.teamFilterBound === '1') return;
        button.dataset.teamFilterBound = '1';

        button.addEventListener('click', () => {
          teamFilterButtons.forEach(btn => btn.classList.remove('active'));
          button.classList.add('active');
          applyTeamFilter(button.dataset.filter || 'all');
        });
      });
    } 

    let statusProgressTimer;
    let statusFallbackAttempts = 0;
    const STATUS_MAX_FALLBACK_ATTEMPTS = 12;

    function setStatusProgress(value, label) {
      const bar = document.getElementById("status-load-bar");
      const text = document.getElementById("status-load-text");
      if (bar) {
        const bounded = Math.max(0, Math.min(100, value));
        bar.style.width = `${bounded}%`;
        bar.setAttribute("aria-valuenow", bounded.toString());
        bar.textContent = `${bounded}%`;
      }
      if (text && label) text.textContent = label;
    }

    function startStatusProgress() {
      clearInterval(statusProgressTimer);
      let value = 8;
      setStatusProgress(value, "Fetching Kanban + GitHub data...");

      // Simulate meaningful progress while waiting for network-bound API work.
      statusProgressTimer = setInterval(() => {
        value = Math.min(92, value + Math.max(1, Math.round((95 - value) * 0.12)));
        setStatusProgress(value);
      }, 450);
    }

    function completeStatusProgress(message) {
      clearInterval(statusProgressTimer);
      setStatusProgress(100, message || "Status metrics loaded.");
      const panel = document.getElementById("status-load-panel");
      if (panel) {
        panel.classList.remove("alert-info");
        panel.classList.add("alert-success");
      }
      const bar = document.getElementById("status-load-bar");
      if (bar) bar.classList.remove("progress-bar-animated");
    }

    function hasRenderableStatusContent(frame) {
      if (!frame) return false;

      // Success state: explicit marker rendered only by _status_content partial.
      return Boolean(frame.querySelector('[data-status-content-ready="1"]'));
    }

    // Fallback loader: only runs if Turbo frame hydration appears stuck.
    async function ensureStatusContentLoaded() {
      const frame = document.getElementById("semester-status-content");
      if (!frame) return;

      // Skip if content appears loaded already.
      if (hasRenderableStatusContent(frame) || frame.dataset.loaded === "1") return;
      if (frame.hasAttribute("busy")) return;
      if (frame.dataset.fallbackFetchStarted === "1") return;

      const src = frame.getAttribute("src");
      if (!src) return;

      try {
        frame.dataset.fallbackFetchStarted = "1";
        const response = await fetch(src, {
          headers: {
            Accept: "text/html"
          },
          credentials: "same-origin"
        });
        if (!response.ok) return;

        const html = await response.text();
        const parsed = new DOMParser().parseFromString(html, "text/html");
        const returnedFrame = parsed.getElementById("semester-status-content");

        // Only inject known status payload shapes to avoid replacing the frame
        // with unrelated HTML (e.g., redirects or full-page responses).
        if (returnedFrame) {
          frame.innerHTML = returnedFrame.innerHTML;
        } else if (parsed.querySelector('[data-status-content-ready="1"]')) {
          frame.innerHTML = html;
        }

        if (hasRenderableStatusContent(frame)) {
          frame.dataset.loaded = "1";
          completeStatusProgress("Status metrics loaded.");
          initTooltipsAndSprintFilter();
        } else {
          setStatusProgress(95, "Still loading metrics... retrying.");
        }
      } catch (_e) {
      } finally {
        frame.dataset.fallbackFetchStarted = "0";
      }
    }

    function scheduleStatusFallback() {
      setTimeout(async () => {
        const frame = document.getElementById("semester-status-content");
        if (!frame || frame.dataset.loaded === "1") return;

        // Allow Turbo enough time first; then do guarded retries while waiting.
        if (!frame.hasAttribute("busy") && statusFallbackAttempts < STATUS_MAX_FALLBACK_ATTEMPTS) {
          statusFallbackAttempts += 1;
          await ensureStatusContentLoaded();
        }

        if (frame.dataset.loaded !== "1" && statusFallbackAttempts < STATUS_MAX_FALLBACK_ATTEMPTS) {
          scheduleStatusFallback();
        } else if (frame.dataset.loaded !== "1") {
          setStatusProgress(96, "Still loading metrics. GitHub requests are taking longer than usual.");
          const panel = document.getElementById("status-load-panel");
          if (panel) {
            panel.classList.remove("alert-success");
            panel.classList.add("alert-info");
          }
        }
      }, 5000);
    }

    document.addEventListener("DOMContentLoaded", initTooltipsAndSprintFilter);
    document.addEventListener("turbo:load", initTooltipsAndSprintFilter);
    document.addEventListener("DOMContentLoaded", startStatusProgress);
    document.addEventListener("turbo:load", startStatusProgress);
    document.addEventListener("turbo:frame-load", (event) => {
      if (event.target && event.target.id === "semester-status-content") {
        if (hasRenderableStatusContent(event.target)) {
          event.target.dataset.loaded = "1";
          completeStatusProgress("Status metrics loaded.");
          initTooltipsAndSprintFilter();
        } else {
          setStatusProgress(95, "Still loading metrics...");
        }
      }
    });
    document.addEventListener("DOMContentLoaded", scheduleStatusFallback);
    document.addEventListener("turbo:load", scheduleStatusFallback);
  </script>
