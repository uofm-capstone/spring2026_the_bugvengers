<%= render "shared/page_header",
  title: "Edit User Account",
  subtitle: "Update your email or password for Tool-Assisted Grading." %>

<section class="auth-edit">
  <article class="ui-card auth-edit__card">
    <div class="ui-card__body">
      <%= bootstrap_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "auth-edit__form" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="auth-edit__section">
          <p class="auth-edit__hint">To change your email address, enter a new one.</p>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", label: "Email" %>

          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <p class="auth-edit__pending">Currently waiting confirmation for: <strong><%= resource.unconfirmed_email %></strong></p>
          <% end %>
        </div>

        <div class="auth-edit__section">
          <p class="auth-edit__hint">To change your password, enter a new one and re-enter to confirm.</p>
          <%= f.password_field :password, autocomplete: "new-password", label: "Password" %>

          <% if @minimum_password_length %>
            <p class="auth-edit__pending"><%= @minimum_password_length %> characters minimum</p>
          <% end %>

          <%= f.password_field :password_confirmation, autocomplete: "new-password", label: "Password confirmation" %>
        </div>

        <div class="auth-edit__section">
          <p class="auth-edit__hint">To save your changes, enter your existing password.</p>
          <%= f.password_field :current_password, autocomplete: "current-password", label: "Current password" %>
        </div>

        <div class="auth-edit__actions">
          <%= f.submit "Update", class: "btn btn-ui-primary" %>
        </div>
      <% end %>
    </div>
  </article>
</section>
