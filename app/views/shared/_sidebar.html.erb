<aside class="app-sidebar" aria-label="Primary navigation">
  <div class="app-sidebar__header">Navigation</div>

  <nav class="app-sidebar__group" aria-label="Main sections">
    <%= nav_link_to "Semesters", semesters_path, class: "app-sidebar__link", active_when: -> { controller_name == "semesters" && action_name != "status" } do %>
      <i class="bi bi-calendar3 me-2" aria-hidden="true"></i> Semesters
    <% end %>

    <%= nav_link_to "Teams", teams_path, class: "app-sidebar__link", active_when: { controller: "teams" } do %>
      <i class="bi bi-people me-2" aria-hidden="true"></i> Teams
    <% end %>

    <%= nav_link_to "Students", students_path, class: "app-sidebar__link", active_when: { controller: "students" } do %>
      <i class="bi bi-mortarboard me-2" aria-hidden="true"></i> Students
    <% end %>

    <%= nav_link_to "Status", status_page_path, class: "app-sidebar__link", active_when: { controller: "semesters", action: "status" } do %>
      <i class="bi bi-bar-chart me-2" aria-hidden="true"></i> Status
    <% end %>
  </nav>
</aside>
