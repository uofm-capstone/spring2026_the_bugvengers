<%= render "shared/page_header",
  title: "Semester Status",
  subtitle: "Upload per-sprint CSV files to refresh semester grading and survey data." %>

<section class="semesters-status__list">
  <% @sprint_list.each do |sprint| %>
    <article class="ui-card semesters-status__item">
      <div class="ui-card__body">
        <h3 class="semesters-status__title"><%= sprint %> CSV Upload</h3>

        <%= form_with model: @semester, url: semester_path(@semester), method: :patch, local: true, html: { multipart: true } do |f| %>
          <div class="row g-2 align-items-center">
            <div class="col-md-10">
              <%= f.file_field :student_csv, accept: '.csv', class: 'form-control' %>
              <%= hidden_field_tag :sprint_number, sprint %>
            </div>
            <div class="col-md-2">
              <%= f.submit "Upload", class: "btn btn-ui-primary w-100" %>
            </div>
          </div>
        <% end %>
      </div>
    </article>
  <% end %>
</section>
