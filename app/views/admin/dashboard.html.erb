<%= render "shared/page_header",
  title: "Admin Dashboard",
  subtitle: "Manage user access and roles for the current TAG deployment." %>

<section class="stat-grid" aria-label="Dashboard summary metrics">
  <%= render "shared/stat_card", label: "Total Users", value: @dashboard_stats[:total_users] %>
  <%= render "shared/stat_card", label: "Staff (Admin + TA)", value: @dashboard_stats[:staff_users] %>
  <%= render "shared/stat_card", label: "Students", value: @dashboard_stats[:students] %>
  <%= render "shared/stat_card", label: "Semesters", value: @dashboard_stats[:semesters] %>
</section>


<section class="admin-dashboard__table-card">
  <div class="ui-card__body">
  <h2 style="margin-bottom: 10px;">User Management</h2>
  <%= form_with url: admin_dashboard_path, method: :get, local: true, class: "ui-form" do |f| %>
    <div style="display: flex; gap: 10px; align-items: center;">
      <%= f.text_field :search,
            value: params[:search],
            placeholder: "Search users by email or name...",
            class: "ui-input",
            style: "flex: 1;" %>

      <%= f.submit "Search", class: "btn btn-primary" %>

      <%= link_to "Clear",
            admin_dashboard_path,
            class: "btn btn-secondary" %>
    </div>
  <% end %>
  </div>
  <div class="ui-table-wrap">
    <table class="table ui-table">
      <thead class="text-center">
        <tr>
          <th>ID</th>
          <th>Email</th>
          <th>Role</th>
          <th>Actions</th>
          <th>Last Logged In</th>
        </tr>
      </thead>
      <tbody class="text-center">
        <% @users.each do |user| %>
          <tr>
            <td><%= user.id %></td>
            <td><%= user.email %></td>
            <td><%= role_badge(user) %></td>
            <td>
              <div class="admin-dashboard__actions">
                <% if can? :update, user %>
                  <div class="dropdown">
                    <button class="btn btn-sm btn-ui-primary dropdown-toggle" type="button" id="roleDropdown<%= user.id %>" data-bs-toggle="dropdown" aria-expanded="false">
                      Change Role
                    </button>
                    <ul class="dropdown-menu" aria-labelledby="roleDropdown<%= user.id %>">
                      <% assignable_roles_for(user, current_user).each do |role| %>
                        <li>
                          <%= button_to role.titleize, admin_update_role_path(user, role: role), method: :patch, class: "dropdown-item" %>
                        </li>
                      <% end %>
                    </ul>
                  </div>
                <% end %>

                <% if can? :destroy, user %>
                  <%= button_to admin_delete_user_path(user),
                        method: :delete,
                        data: { confirm: 'Are you sure?' },
                        class: "icon-button",
                        form: { class: "d-inline" },
                        aria: { label: "Delete user #{user.email}" } do %>
                    <i class="bi bi-trash-fill" aria-hidden="true"></i>
                  <% end %>
                <% end %>
              </div>
            </td>
            <td>
              <%= user.last_login_at ? user.last_login_at.strftime("%Y-%m-%d %H:%M") : "Never" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
