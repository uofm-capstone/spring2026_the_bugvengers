<%= render "shared/page_header",
  title: "Classlist",
  subtitle: "#{@semester.name_for_select}" %>

<section class="semesters-classlist__card ui-card">
  <div class="ui-card__body">
    <div class="ui-table-wrap">
      <table class="table ui-table">
        <% if @students_info.any? %>
          <thead>
            <tr>
              <th>Name</th>
              <th>Role</th>
            </tr>
          </thead>
          <tbody>
            <% @students_info.each do |student| %>
              <tr>
                <td><%= student[:name] %></td>
                <td><%= student[:role] %></td>
              </tr>
            <% end %>
          </tbody>
        <% else %>
          <tbody>
            <tr>
              <td colspan="2" class="text-center text-muted">No students found for this semester.</td>
            </tr>
          </tbody>
        <% end %>
      </table>
    </div>
  </div>
</section>
