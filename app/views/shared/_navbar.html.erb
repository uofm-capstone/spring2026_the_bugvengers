<header class="topbar">
  <div class="topbar__left">
    <%= link_to home_path, class: "topbar__brand" do %>
      <span class="topbar__brand-mark" aria-hidden="true">TAG</span>
      <span class="topbar__brand-text">Tool-Assisted Grading</span>
    <% end %>
  </div>

  <div class="topbar__center">
    <%= render 'shared/team_sprint_dropdowns' if controller_name == 'semesters' && action_name == 'team' %>
  </div>

  <div class="topbar__right">
    <% if current_user && (current_user.admin? || current_user.ta?) %>
      <%= link_to 'Admin Dashboard', admin_dashboard_path, class: "topbar__link" %>
    <% end %>

    <div class="dropdown">
      <a class="topbar__account dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-person-circle me-1" aria-hidden="true"></i>
        <% if user_signed_in? %>
          <span><%= current_user.email %></span>
        <% else %>
          <span>Sign In</span>
        <% end %>
      </a>

      <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
        <% if user_signed_in? %>
          <li><%= link_to 'Edit Profile', edit_user_registration_path, class: 'dropdown-item' %></li>
          <li><%= button_to 'Sign Out', destroy_user_session_path, method: :delete, class: 'dropdown-item' %></li>
        <% else %>
          <li><%= link_to 'Sign In', new_user_session_path, class: 'dropdown-item' %></li>
        <% end %>
      </ul>
    </div>
  </div>
</header>
